{
  "name": "@open-posting/cli",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "op": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --clean",
