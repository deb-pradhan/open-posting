# === Required ===
DATABASE_URL=postgresql://openposting:openposting@localhost:5433/openposting  # Docker maps 5432→5433
REDIS_URL=redis://localhost:6380                                              # Docker maps 6379→6380
ENCRYPTION_KEY=                                  # Generate: openssl rand -hex 32
PUBLIC_URL=http://localhost:3000                  # For OAuth callbacks

# === X (Twitter) — Official API ===
X_CLIENT_ID=
X_CLIENT_SECRET=
X_BEARER_TOKEN=

# === X (Twitter) — GetXAPI (Fallback) ===
X_GETXAPI_KEY=

# === LinkedIn ===
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# === Media Storage ===
MEDIA_STORAGE_PATH=/data/media
MEDIA_MAX_STORAGE_GB=10
MEDIA_SERVE_BASE_URL=

# === Optional ===
LOG_LEVEL=info
API_RATE_LIMIT=100
PORT=3000
OTEL_EXPORTER_OTLP_ENDPOINT=
WEBHOOK_URL=
